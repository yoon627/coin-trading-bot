# Upbit API
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# Trading
TRADING_TICKERS=KRW-BTC,KRW-ETH
TRADING_STRATEGY=combined
TRADING_INVEST_RATIO=0.1
TRADING_MAX_INVEST_AMOUNT=100000
TRADING_TAKE_PROFIT_PCT=2.0
TRADING_MAX_LOSS_PCT=5.0
TRADING_TRAILING_STOP_PCT=2.0
# 트레일링 arm 임계(%) — 고점 수익률 도달 후에만 트레일링 평가. 0=수익 중 즉시. trail 보다 클 때만 실효
TRADING_TRAILING_ARM_PCT=0.0
# 보유 상한(거래일, KST 09:00 경계) — 1=일일리셋
TRADING_MAX_HOLD_DAYS=1
# 차트/지표 기반 청산(데드크로스 등) 토글
TRADING_CHART_EXIT_ENABLED=false
# 왕복 수수료 비율(기록용 net pnl 차감) — Upbit 0.05%x2
TRADING_ROUND_TRIP_FEE_RATE=0.001

# Discord Notification (optional)
DISCORD_WEBHOOK_URL=
# Error alert (opt-in): use a separate webhook/channel.
# enabled=true + URL -> server ERROR logs are sent to that channel.
DISCORD_ERROR_ALERT_ENABLED=false
DISCORD_ERROR_WEBHOOK_URL=

# Database (prod profile)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading
DB_USER=trading
DB_PASSWORD=trading
