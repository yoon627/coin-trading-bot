{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Application Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"coin-trading-bot\"}", "legendFormat": "Up" }],
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }] } }
    },
    {
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
      "targets": [{ "expr": "jvm_memory_used_bytes{application=\"coin-trading-bot\"}", "legendFormat": "{{area}} - {{id}}" }]
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(http_server_requests_seconds_count{application=\"coin-trading-bot\"}[5m])", "legendFormat": "{{method}} {{uri}}" }]
    },
    {
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(http_server_requests_seconds_count{application=\"coin-trading-bot\",status=~\"4..|5..\"}[5m])", "legendFormat": "{{status}} {{uri}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "HTTP Response Time P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"coin-trading-bot\"}[5m]))", "legendFormat": "p99 {{uri}}" }]
    },
    {
      "title": "Active Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "targets": [{ "expr": "jvm_threads_live_threads{application=\"coin-trading-bot\"}", "legendFormat": "Threads" }]
    },
    {
      "title": "Database Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "r2dbc_pool_acquired_size{application=\"coin-trading-bot\"}", "legendFormat": "Acquired" },
        { "expr": "r2dbc_pool_idle_size{application=\"coin-trading-bot\"}", "legendFormat": "Idle" },
        { "expr": "r2dbc_pool_pending_count{application=\"coin-trading-bot\"}", "legendFormat": "Pending" }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{ "expr": "process_cpu_usage{application=\"coin-trading-bot\"}", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ],
  "schemaVersion": 38,
  "tags": ["trading-bot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Coin Trading Bot",
  "uid": "coin-trading-bot"
}
