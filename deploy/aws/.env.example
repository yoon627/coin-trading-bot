# ── AWS ──
AWS_REGION=ap-northeast-2
APP_NAME=coin-trading-bot
INSTANCE_TYPE=t4g.medium          # 4GB ARM. 예산 더 줄이려면 t4g.small(2GB) / x86 는 t3.small
EBS_SIZE_GB=20

# 접근 제한 (보안). 비우면 setup 시 현재 공인 IP/32 로 자동 제한.
# 확인: curl -s https://checkip.amazonaws.com
SSH_ALLOW_CIDR=
APP_ALLOW_CIDR=                   # 비우면 SSH_ALLOW_CIDR 과 동일. 어디서나 대시보드 접근하려면 0.0.0.0/0 (비권장)

# ── 이미지 (GitHub Actions 가 GHCR 로 push) ──
GHCR_IMAGE=ghcr.io/yoon627/coin-trading-bot
APP_VERSION=latest
# GHCR 패키지가 private 이면 read:packages 권한 PAT 필요. public 으로 바꾸면 생략 가능.
GHCR_USERNAME=
GHCR_TOKEN=

# ── 앱 시크릿 (비우면 setup/deploy 시 자동 생성되어 이 파일에 저장됨) ──
# APP_ENCRYPTION_SECRET 은 저장된 Upbit 키를 복호화하는 AES 키. 한번 생성되면 절대 바꾸지 말 것.
DB_PASSWORD=
JWT_SECRET=
APP_ENCRYPTION_SECRET=

# ── Upbit API (선택: 전역/단일계정용. 멀티유저는 앱 안에서 유저별 키 등록) ──
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# ── 트레이딩 ──
TRADING_TICKERS=KRW-BTC
TRADING_STRATEGY=combined
TRADING_AUTO_START=false
TRADING_TAKE_PROFIT_PCT=2.0
TRADING_MAX_LOSS_PCT=5.0
TRADING_TRAILING_STOP_PCT=2.0
# 트레일링 arm 임계(%) — 고점 수익률 도달 후에만 트레일링 평가. 0=수익 중 즉시. trail 보다 클 때만 실효
TRADING_TRAILING_ARM_PCT=0.0
# 보유 상한(거래일, KST 09:00 경계) — 1=일일리셋
TRADING_MAX_HOLD_DAYS=1
# 차트/지표 기반 청산(데드크로스 등) 토글
TRADING_CHART_EXIT_ENABLED=false
# 왕복 수수료 비율(기록용 net pnl 차감) — Upbit 0.05%x2
TRADING_ROUND_TRIP_FEE_RATE=0.001

# ── Discord 웹훅 (선택) ──
DISCORD_WEBHOOK_URL=
# 에러 알림 (opt-in): 거래 채널과 분리된 별도 webhook 권장.
# enabled=true + URL 설정 시 서버 ERROR 로그를 해당 채널로 전송.
DISCORD_ERROR_ALERT_ENABLED=false
DISCORD_ERROR_WEBHOOK_URL=

# ── TLS / 도메인 ──
# Caddy 가 이 도메인으로 Let's Encrypt 인증서를 자동 발급/갱신한다(HTTPS 종단).
# 비우면 deploy.sh 가 EC2 공인 IP 기반 sslip.io 도메인(예: 13-125-170-147.sslip.io)으로 자동 생성.
# 보유 도메인을 쓰려면 그 도메인의 A 레코드를 EC2 IP 로 연결한 뒤 여기에 적는다.
APP_DOMAIN=

# TLS 가 Caddy 로 종단되므로 평소 false 유지. true 는 TLS 없이 HTTP 로만 임시 운영할 때만
# (그동안 JWT 쿠키가 평문 HTTP 로 전송됨). 정상 운영에선 켜지 말 것.
APP_AUTH_COOKIE_FORCE_INSECURE=false
