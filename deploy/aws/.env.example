# AWS 설정
AWS_REGION=ap-northeast-2
APP_NAME=coin-trading-bot

# SSH 접속 허용 IP (보안을 위해 본인 IP/32 권장)
# 확인: curl -s ifconfig.me
SSH_ALLOW_CIDR=0.0.0.0/0

# RDS 마스터 비밀번호 (8자 이상, 영문+숫자)
DB_MASTER_PASSWORD=

# Upbit API 키
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# 트레이딩 설정
TRADING_TICKERS=KRW-BTC
TRADING_STRATEGY=volatility_breakout
TRADING_AUTO_START=false

# Discord 웹훅 (선택)
DISCORD_WEBHOOK_URL=
